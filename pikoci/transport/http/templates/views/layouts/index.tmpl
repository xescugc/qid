          'click': 'clickCard',
        },
        initialize: function() {
          this.image = new app.PipelineImage(null, {pipeline: this.model})
          this.image.fetch()
          this.listenTo(this.image, "change", this.updateStatus)
        },
        render: function () {
          this.$el.html(this.template(this.model.toJSON()));
          this.$el.find(".card-img-top").html(new app.PipelineGraphView({model: this.image, noLinks: true}).render().el)
          return this; // enable chained calls
        },
        updateStatus: function() {
          var that = this
          var attempts = 0
          function checkSvg() {
            var svg = that.$el.find("svg")[0]
            if (!svg) {
              if (attempts++ < 20) setTimeout(checkSvg, 200)
              return
            }
            var hasFailed = false, hasRunning = false, hasSucceeded = false
            svg.querySelectorAll('polygon, rect, ellipse, path').forEach(function(el) {
              var fill = (el.getAttribute("fill")||"").toLowerCase()
              if (fill === "#ff004d") hasFailed = true
              if (fill === "#ffa300") hasRunning = true
              if (fill === "#00a83a") hasSucceeded = true
            })
            var html = ''
            if (hasFailed) {
              html = '<span class="piko-card-status-dot" style="background:#FF004D;"></span> Last build failed'
            } else if (hasRunning) {
              html = '<span class="piko-card-status-dot" style="background:#FFA300;"></span> Running'
            } else if (hasSucceeded) {
              html = '<span class="piko-card-status-dot" style="background:#00A83A;"></span> Last build passed'
            } else {
              html = '<span style="color:var(--text-muted);">No builds</span>'
            }
            that.$el.find(".piko-card-status").html(html)
          }
          setTimeout(checkSvg, 300)
        },
        clickCard: function(event) {
          event.preventDefault();
          app.router.navigate(this.model.url(), { trigger: true });
        },
      })
