<!DOCTYPE html>
<html lang="en">
  <head>
    <title>PikoCI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/css/pikoci.css" rel="stylesheet" />
    <link href="/images/favicon.png" rel="icon" type="image/png"/>
  </head>

  <body>
    <div id="app">
    </div>
    <h1>

    <script type = "text/javascript" src="/js/jquery.min.js"></script>
    <script type = "text/javascript" src="/js/underscorejs.min.js"></script>
    <script type = "text/javascript" src="/js/backbonejs.min.js"></script>
    <script type = "text/javascript" src="/js/bootstrap.bundle.min.js"></script>
    <script type = "text/javascript" src="/js/viz-global.js"></script>

    <script type="text/template" id="main-view">
      <header>
      </header>
      <main class="container">
        <div id="error"></div>
        <div id="breadcrumb"></div>
        <div id="main"></div>
      </main>
      <footer>
      </footer>
    </script>

    <script type="text/template" id="header-view">
      <nav class="navbar">
        <div class="container-fluid">
          <a class="navbar-brand" id="logo" href="/">
            <img src="/images/logo.png" alt="Logo" width="45" height="25" class="d-inline-block align-text-top">
            PikoCI
          </a>
          <% if (session) { %>
            <div class="dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                <%- session.user.full_name %>
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li>
                  <a class="dropdown-item d-flex align-items-center justify-content-between" href="#" onclick="event.preventDefault(); event.stopPropagation(); toggleTheme();">
                    <span>Dark Mode</span>
                    <span class="piko-toggle" id="theme-toggle">
                      <span class="piko-toggle-thumb"></span>
                    </span>
                  </a>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" id="logout" href="/logout">Logout</a></li>
              </ul>
            </div>
          <% } %>
        </div>
      </nav>
    </script>

    <script type="text/template" id="error-view">
      <div>
        <% if (error) { %>
          <div class="alert alert-danger" role="alert">
            <%- error %>
          </div>
        <% } %>
      </div>
    </script>

    <script type="text/template" id="session-new-view">
      <div class="piko-login-wrapper">
        <div class="piko-login-box">
          <div class="text-center mb-4">
            <img src="/images/logo.png" alt="QID" width="45" height="25" class="mb-2">
            <h1 class="h4 fw-bold">Log In</h1>
          </div>
          <form>
            <div class="mb-3">
              <label for="username" class="form-label">Username</label>
              <input type="text" class="form-control" id="username" placeholder="Enter username">
            </div>
            <div class="mb-3">
              <label for="password" class="form-label">Password</label>
              <input type="password" class="form-control" id="password" placeholder="Enter password">
            </div>
            <button type="submit" id="login" class="btn btn-primary w-100">Log In</button>
          </form>
        </div>
      </div>
    </script>

    <script type="text/template" id="teams-view">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h4 fw-bold mb-0">Teams</h1>
        <% if (isAdmin()) { %>
          <a type="button" id="team-new" class="btn btn-success" href="/teams/new">+ New</a>
        <% } %>
      </div>
      <div id="team-list">
      </div>
    </script>

    <script type="text/template" id="teams-new-view">
      <div class="mb-3">
        <h1 class="h4 fw-bold">New Team</h1>
      </div>
      <form style="max-width:480px;">
        <div class="mb-3">
          <label for="name" class="form-label">Name</label>
          <input type="text" class="form-control" id="name" value="<%- name %>" placeholder="e.g. platform-team" <%- id ? "disabled" : ""%>>
        </div>
        <button type="submit" class="btn btn-primary">Create</button>
      </form>
    </script>

    <script type="text/template" id="team-row-view">
      <div class="piko-team-name"><%- name %></div>
      <div class="piko-team-actions">
        <a id="pipelines" href="/teams/<%- canonical %>/pipelines" type="button" class="btn btn-primary">Pipelines</a>
        <a id="manage" href="/teams/<%- canonical %>" type="button" class="btn btn-info">Manage</a>
        <% if (isAdmin(canonical)) { %>
          <button id="delete" type="button" class="btn btn-danger">Delete</button>
        <% } %>
      </div>
    </script>

    <script type="text/template" id="team-show-view">
      <div class="mb-3">
        <h1 class="h4 fw-bold">Team: <%- name %></h1>
      </div>
      <form style="max-width:480px;">
        <div class="mb-3">
          <label for="name" class="form-label">Name</label>
          <input type="text" class="form-control" id="name" value="<%- name %>"
            <% if (!isAdmin(canonical)) { %>
              disabled=""
            <% } %>
          >
        </div>
        <% if (isAdmin(canonical)) { %>
          <button type="submit" class="btn btn-primary">Update</button>
        <% } %>
      </form>
      <hr style="border-color: var(--border); margin: 1.5rem 0;">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 class="h5 fw-bold mb-0">Members</h3>
        <% if (isAdmin(canonical)) { %>
          <a type="button" id="new-member" class="btn btn-success">+ New Member</a>
        <% } %>
      </div>
      <table class="table">
        <thead>
          <tr>
            <th scope="col" class="col-5">Full Name</th>
            <th scope="col" class="col-5">Admin</th>
            <th scope="col" class="col-2">Options</th>
          </tr>
        </thead>
        <tbody>
        </tbody>
      </table>
    </script>

    <script type="text/template" id="team-new-member-row-view">
      <td>
				<select class="form-select" id="username">
          <% _.each(members, function(m) { %>
            <option value="<%- m.username %>"><%- m.full_name %></option>
          <% }) %>
				</select>
      </td>
      <td>
				<div class="form-check form-switch">
					<input class="form-check-input" type="checkbox" role="switch" id="admin" />
				</div>
      </td>
      <td>
				<div class="btn-group" role="group">
					<button id="create" type="button" class="btn btn-success">Create</button>
				</div>
      </td>
    </script>

    <script type="text/template" id="team-show-member-row-view">
      <td><%- member.user.full_name %></td>
      <td>
				<div class="form-check form-switch">
					<input class="form-check-input" type="checkbox" role="switch" id="admin"
            <% if (member.admin) { %>
              checked=""
            <% } %>

            <% if (!isAdmin(team.canonical)) { %>
              disabled=""
            <% } %>
          />
				</div>
      </td>
      <td>
				<div class="btn-group" role="group">
          <% if (isAdmin(team.canonical)) { %>
					  <button id="delete" type="button" class="btn btn-danger">Delete</button>
          <% } %>
				</div>
      </td>
    </script>

    <script type="text/template" id="pipelines-view">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h4 fw-bold mb-0">Pipelines</h1>
        <% if (isAdmin(team.canonical)) { %>
          <a type="button" id="pipelines-new" class="btn btn-success" href="/teams/<%- team.canonical %>/pipelines/new">+ New</a>
        <% } %>
      </div>
      <div class="row row-cols-1 row-cols-md-3 g-4" id="pipelines">
      </div>
    </script>

    <script type="text/template" id="pipelines-card-view">
      <div class="card h-100">
        <div class="card-header">
          <%- name %>
        </div>
        <div class="card-img-top">
        </div>
        <div class="card-footer piko-card-status">
          <span style="color:var(--text-muted);">Loading...</span>
        </div>
      </div>
    </script>

    <script type="text/template" id="pipeline-show-view">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h4 fw-bold mb-0"><%- pipeline.name %></h1>
        <% if (isAdmin(team.canonical)) { %>
          <div class="btn-group">
            <button type="button" id="edit-pipeline" class="btn btn-info">Edit</button>
            <button type="button" id="delete-pipeline" class="btn btn-danger">Delete</button>
          </div>
        <% } %>
      </div>
      <div class="piko-graph-container" id="graphviz"></div>
      <div class="piko-graph-legend">
        <span class="piko-graph-legend-item">
          <svg width="22" height="14" viewBox="0 0 22 14"><polygon points="0,0 16,0 22,7 16,14 0,14" fill="#83769C" stroke="#5F574F" stroke-width="1"/></svg>
          Resource
        </span>
        <span class="piko-graph-legend-item">
          <span class="piko-graph-legend-swatch" style="background:var(--status-succeeded);"></span>
          Succeeded
        </span>
        <span class="piko-graph-legend-item">
          <span class="piko-graph-legend-swatch" style="background:var(--status-failed);"></span>
          Failed
        </span>
        <span class="piko-graph-legend-item">
          <span class="piko-graph-legend-swatch" style="background:var(--status-started);border:1.5px dashed var(--status-started);"></span>
          Running
        </span>
        <span class="piko-graph-legend-item">
          <span class="piko-graph-legend-swatch" style="background:#83769C;"></span>
          No builds
        </span>
      </div>
    </script>

    <script type="text/template" id="pipeline-graph-view">
      <div id="pipeline-graph"></div>
    </script>

    <script type="text/template" id="pipelines-new-view">
      <div class="mb-3">
        <h1 class="h4 fw-bold"><%- id ? "Update Pipeline":"New Pipeline" %></h1>
      </div>
      <form>
        <div class="mb-3" style="max-width:480px;">
          <label for="name" class="form-label">Name</label>
          <input type="text" class="form-control" id="name" value="<%- name %>" placeholder="e.g. deploy-production" <%- id ? "disabled" : ""%>>
        </div>
        <div class="row g-4">
          <div class="col-md-6">
            <div class="mb-3">
              <label for="pipeline" class="form-label">Pipeline Definition</label>
              <textarea type="text" rows="20" class="form-control" id="pipeline"><%- raw %></textarea>
            </div>
            <div class="mb-3">
              <label for="vars" class="form-label">Vars</label>
              <textarea type="text" rows="10" class="form-control" id="vars"></textarea>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label">Graph Preview</label>
            <div id="graph" style="background: var(--bg-muted); border: 1px solid var(--border); border-radius: var(--radius); min-height: 200px;">
            </div>
          </div>
        </div>
        <button type="submit" class="btn btn-primary mt-2"><%- id ? "Update":"Create" %></button>
      </form>
    </script>

    <script type="text/template" id="job-builds-view">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h4 fw-bold mb-0"><%- job.name %></h1>
        <% if (isMember(team.canonical)) { %>
          <button type="button" id="trigger-job" class="btn btn-warning">Trigger Job</button>
        <% } %>
      </div>
      <div class="piko-build-tabs" id="builds-tabs">
      </div>
      <div id="builds-content">
      </div>
    </script>

    <script type="text/template" id="breadcrumb-view">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Teams</a></li>
        <% if (team) { %>
          <% if (!pipeline && !showPipelines) { %>
            <li class="breadcrumb-item active"><%- team.name %></li>
          <% } else { %>
            <li class="breadcrumb-item"><a href="/teams/<%- team.canonical %>"><%- team.name %></a></li>
            <% if (showPipelines) { %>
              <li class="breadcrumb-item active">Pipelines</li>
            <% } else { %>
              <li class="breadcrumb-item"><a href="/teams/<%- team.canonical %>/pipelines">Pipelines</a></li>
            <% } %>
          <% } %>
        <% } %>
        <% if (pipeline) { %>
          <% if (!job && !resource) { %>
            <li class="breadcrumb-item active"><%- pipeline.name %></li>
          <% }  else {%>
            <li class="breadcrumb-item"><a href="/teams/<%- team.canonical %>/pipelines/<%- pipeline.name %>"><%- pipeline.name %></a></li>
          <% } %>
        <% } %>
        <% if (job) { %>
          <li class="breadcrumb-item active">Jobs</li>
          <li class="breadcrumb-item active"><%- job.name %></li>
          <li class="breadcrumb-item active">Builds</li>
        <% } %>
        <% if (resource) { %>
          <li class="breadcrumb-item active">Resources</li>
          <li class="breadcrumb-item active"><%- resource.canonical %></li>
          <li class="breadcrumb-item active">Versions</li>
        <% } %>
      </ol>
    </script>

    <script type="text/template" id="job-builds-tab-view">
      #<%- id %>
      <span class="piko-tab-status"></span>
    </script>

    <script type="text/template" id="job-builds-content-view">
      <div class="piko-build-content-inner">
        <% if (error) { %>
          <div class="alert alert-danger" role="alert">
            <%- error %>
          </div>
        <% } %>
        <div class="piko-build-meta">
          <span><span class="piko-build-label">Started</span> <%- new Date(started_at).toLocaleString() %></span>
          <% if (duration !== 0 ) { %>
            <span><span class="piko-build-label">Duration</span> <%- duration %></span>
          <% } %>
          <% if (status === "succeeded") { %>
            <span class="piko-badge piko-badge-succeeded">Succeeded</span>
          <% } else if (status === "failed") { %>
            <span class="piko-badge piko-badge-failed">Failed</span>
          <% } else if (status === "started") { %>
            <span class="piko-badge piko-badge-started">Running</span>
          <% } %>
        </div>
        <% var _steps = steps || []; %>
        <% var _job = job || []; %>
        <% var lastStep = _steps.length > 0 ? _steps[_steps.length-1] : null; %>
        <% _.each(_steps, function(s, i) { %>
          <div class="piko-step-row">
            <div class="piko-step-row-header" onclick="this.nextElementSibling.style.display = this.nextElementSibling.style.display === 'none' ? 'block' : 'none'">
              <span><span class="piko-step-label"><%- s.type || "step" %></span> <%- s.name %> <span style="color:var(--text-muted);">(<%- s.duration %>)</span></span>
              <% if (status === "failed" && s === lastStep && _job.length === 0) { %>
                <span class="piko-badge piko-badge-failed">fail</span>
              <% } else if (status === "started" && s === lastStep && _job.length === 0) { %>
                <span class="piko-badge piko-badge-started">running</span>
              <% } else if (s.logs) { %>
                <span class="piko-badge piko-badge-succeeded">ok</span>
              <% } %>
            </div>
            <div class="piko-step-row-body" style="display:none;">
<pre>
<%- s.logs %>
</pre>
            </div>
          </div>
        <% }) %>
        <% var lastJob = _job.length > 0 ? _job[_job.length-1] : null; %>
        <% _.each(_job, function(j, i) { %>
          <div class="piko-step-row">
            <div class="piko-step-row-header" onclick="this.nextElementSibling.style.display = this.nextElementSibling.style.display === 'none' ? 'block' : 'none'">
              <span><span class="piko-step-label">job</span> <%- j.name %> <span style="color:var(--text-muted);">(<%- j.duration %>)</span></span>
              <% if (status === "failed" && j === lastJob) { %>
                <span class="piko-badge piko-badge-failed">fail</span>
              <% } else if (status === "started" && j === lastJob) { %>
                <span class="piko-badge piko-badge-started">running</span>
              <% } else if (j.logs) { %>
                <span class="piko-badge piko-badge-succeeded">ok</span>
              <% } %>
            </div>
            <div class="piko-step-row-body" style="display:none;">
<pre>
<%- j.logs %>
</pre>
            </div>
          </div>
        <% }) %>
      </div>
    </script>

    <script type="text/template" id="resource-versions-view">
      <% if (resource.logs) { %>
        <div class="alert alert-danger" role="alert">
          <%- resource.logs %>
        </div>
      <% } %>
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h4 fw-bold mb-0"><%- resource.canonical %></h1>
        <% if (isMember(team.canonical)) { %>
          <button type="button" id="trigger-resource" class="btn btn-warning">Trigger Resource</button>
        <% } %>
      </div>
      <div class="piko-resource-info">
        <span class="piko-build-label">Last checked</span> (<%- resource.check_interval||"@every 1m" %>) at: <span style="color: var(--text-primary);"><%- new Date(resource.last_check).toLocaleString() %></span>
      </div>
      <div id="resource-versions">
      </div>
    </script>

    <script type="text/template" id="resource-version-view">
      <div class="piko-version-row">
        <div class="piko-version-row-header" onclick="this.nextElementSibling.style.display = this.nextElementSibling.style.display === 'none' ? 'block' : 'none'">
          <span style="display:flex;align-items:center;gap:8px;">
            <% if (isFirst) { %>
              <span class="piko-badge piko-badge-succeeded">latest</span>
            <% } %>
            <span class="piko-version-kv">
              <% _.mapObject(version, function(v, k) { %>
                <%- k %>: <span><%- v %></span>
              <% }) %>
            </span>
          </span>
        </div>
        <div class="piko-version-row-body" style="display:none;">
          <table class="piko-version-table">
            <tr><td class="piko-version-key">ID</td><td><%- id %></td></tr>
            <% _.mapObject(version, function(v, k) { %>
              <tr><td class="piko-version-key"><%- k %></td><td><%- v %></td></tr>
            <% }) %>
          </table>
        </div>
      </div>
    </script>

    <script type = "text/javascript">
      'use strict';

      // Theme toggle — persisted in localStorage
      (function() {
        var saved = localStorage.getItem('piko-theme');
        if (saved === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
      function toggleTheme() {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('piko-theme', 'light');
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('piko-theme', 'dark');
        }
        syncThemeSwitch();
      }
      function syncThemeSwitch() {
        var t = document.getElementById('theme-toggle');
        if (t) {
          if (document.documentElement.getAttribute('data-theme') === 'dark') {
            t.classList.add('on');
          } else {
            t.classList.remove('on');
          }
        }
      }

      var app = {};
      var fetchInterval = 2000
      var isLogin = true

      var durationToString = function(duration) {
        if (duration === 0) {
          return "00:00:00"
        }
        var secConst = 1000*1000*1000
        var minConst = secConst*60
        var hourConst = minConst*60

        var hours = Math.floor(duration / hourConst)
        var minutes = Math.floor((duration-(hours*hourConst))/minConst)
        var seconds = Math.floor((duration-(minutes*minConst))/secConst)
        hours = hours || "00"
        minutes = minutes || "00"
        seconds = seconds || "00"
        hours +=""
        minutes +=""
        seconds +=""
        if (hours.length === 1) {
          hours = "0"+hours
        }
        if (minutes.length === 1) {
          minutes = "0"+minutes
        }
        if (seconds.length === 1) {
          seconds = "0"+seconds
        }
        return hours+ ":" + minutes + ":" + seconds
      }
      var addSessionFunctions = function(data) {
        return _.extend(app.session.data(), data)
      }

      //--------------
      // Models
      //--------------
      app.Session = Backbone.Model.extend({
        url: "login",
        //defaults: {
        //  username: null,
        //  password: null,
        //},
        parse: function(response) {
          if (response.data){
            return response.data
          }
          return response;
        },
        isEmpty: function() {
          return !this.get("jwt")
        },
        isAdmin: function(tc) {
          if (this.get("user").admin){
            return true
          }
          var admin = false
          if (tc !== "") {
            _.each(this.get("user").memberships, function(m) {
              if (m.admin && m.team_canonical === tc) {
                admin = true
              }
            })
          }
          return admin
        },
        isMember: function(tc) {
          if (this.get("user").admin) {
            return true
          }
          if (tc === "") {
            return true
          }
          var member = false
          _.each(this.get("user").memberships, function(m) {
            if (m.team_canonical === tc) {
              member = true
            }
          })
          return member
        },
        data: function() {
          return {
            isAdmin: this.isAdmin.bind(this),
            isMember: this.isMember.bind(this),
          }
        },
      });
      app.User = Backbone.Model.extend({
        defaults: {
          id: null,
          full_name: null,
          username: null,
          admin: null,
        },
        idAttribute: "username",
      });
      app.Team = Backbone.Model.extend({
        idAttribute: "canonical",
        defaults: {
          id: null,
          name: null,
          canonical: null,
        },
        initialize: function(attr) {
          attr = attr || {}
          if (attr.members && Array.isArray(attr.members)) {
            this.set("members", new app.TeamMembers(attr.members, {team: this}))
          }
        },
        parse: function(response) {
          if (response.data){
            response.data.members = new app.TeamMembers(response.data.members, {team: this})
            return response.data
          }
          response.members = new app.TeamMembers(response.members, {team: this})
          return response;
        }
      });
      app.TeamMember = Backbone.Model.extend({
        initialize: function(attr, opts){
          opts = opts || {}
          this.set("id", attr.user.username)
          this.team = opts.team
        },
        parse: function(response) {
          if (response.data){
            return response.data
          }
          return response;
        }
      })
      app.Pipeline = Backbone.Model.extend({
        idAttribute: "name",
        defaults: {
          id: null,
          raw: null,
          name: null,
        },
        parse: function(response) {
          if (response.data){
            return response.data
          }
          return response;
        }
      });
      app.PipelineImage = Backbone.Model.extend({
        url: function() {
          return this.pipeline.url() + "/image.dot"
        },
        initialize: function(attr, opts) {
          opts = opts || {}
          this.pipeline = opts.pipeline
        },
      });
      app.Job = Backbone.Model.extend({
